#!/bin/sh

# Prevent pushing to branches that have merged PRs on GitHub.
# This catches the mistake of pushing follow-up commits to a branch
# whose PR has already been merged — those commits would be lost.

BRANCH=$(git branch --show-current)

# Skip check for main — always allow pushing to main
if [ "$BRANCH" = "main" ]; then
  exit 0
fi

# Check if gh CLI is available
if ! command -v gh >/dev/null 2>&1; then
  exit 0
fi

# Check if this branch has a merged PR
MERGED=$(gh pr list --head "$BRANCH" --state merged --json number --jq '.[0].number' 2>/dev/null)

if [ -n "$MERGED" ]; then
  echo ""
  echo "ERROR: Branch '$BRANCH' has a merged PR (#$MERGED)."
  echo "Pushing to this branch will NOT update main."
  echo ""
  echo "Create a new branch instead:"
  echo "  git checkout main && git pull && git checkout -b fix/your-fix-name"
  echo ""
  exit 1
fi
