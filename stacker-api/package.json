{
  "name": "stacker-api",
  "version": "1.0.0",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "yarn dev:setup && yarn dev:server",
    "dev:setup": "bash ../scripts/check-env.sh && bash ../scripts/sync-env.sh && bash ../scripts/ensure-docker-db.sh && bash ../scripts/kill-port.sh && node scripts/ensure-db.js && yarn run generate && yarn prisma migrate deploy && yarn prisma db seed",
    "dev:server": "nodemon --signal SIGTERM --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "generate": "prisma generate && node scripts/write-prisma-barrel.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "reset-password": "ts-node --project tsconfig.seed.json scripts/reset-password.ts",
    "seed:export": "ts-node --project tsconfig.seed.json scripts/export-seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^4",
    "@prisma/adapter-mariadb": "^7",
    "@prisma/client": "^7",
    "bcrypt": "^6",
    "cors": "^2",
    "dotenv": "^16",
    "express": "^4",
    "graphql": "^16.14.0",
    "jose": "^6",
    "mariadb": "^3",
    "pino": "^9",
    "pino-pretty": "^13",
    "pino-roll": "^1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5",
    "@types/cors": "^2",
    "@types/express": "^5",
    "@types/node": "^22",
    "eslint": "^10",
    "globals": "^17.6.0",
    "nodemon": "^3",
    "prisma": "^7",
    "ts-node": "^10",
    "typescript": "~6.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  }
}
